# Firebase (produção - projeto radioosceia)
# Copie para .env.production e configure o valor real da API key desse projeto.
VITE_FIREBASE_API_KEY=your-radioosceia-api-key
VITE_FIREBASE_AUTH_DOMAIN=radioosceia.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=radioosceia
VITE_FIREBASE_STORAGE_BUCKET=radioosceia.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=958400769666
VITE_FIREBASE_APP_ID=1:958400769666:web:4c2f9ae3408403ff680e9b
# Opcional (Analytics): VITE_FIREBASE_MEASUREMENT_ID=G-FM21PT7EFN

# Desenvolvimento local com emuladores
VITE_USE_FIREBASE_EMULATORS=true
