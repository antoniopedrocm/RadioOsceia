# Valores padrão de DESENVOLVIMENTO.
# Copie este arquivo para .env.local (dev) ou .env.production (prod) e use as chaves correspondentes.
# Atenção: API key incorreta pode causar erro do Firebase: auth/invalid-api-key.
#
# Exemplo de PRODUÇÃO (radioosceia):
# VITE_FIREBASE_API_KEY=<api-key-de-producao>
# VITE_FIREBASE_AUTH_DOMAIN=radioosceia.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=radioosceia
# VITE_FIREBASE_STORAGE_BUCKET=radioosceia.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=958400769666
# VITE_FIREBASE_APP_ID=1:958400769666:web:4c2f9ae3408403ff680e9b
# Opcional (Analytics): VITE_FIREBASE_MEASUREMENT_ID=G-FM21PT7EFN
VITE_FIREBASE_API_KEY=your-dev-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-dev-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-dev-project
VITE_FIREBASE_STORAGE_BUCKET=your-dev-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-dev-messaging-sender-id
VITE_FIREBASE_APP_ID=your-dev-app-id

# Desenvolvimento local (opcional: com emuladores)
VITE_USE_FIREBASE_EMULATORS=true
