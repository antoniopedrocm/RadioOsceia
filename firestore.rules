rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdminOrOperator() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'operador'];
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdminOrOperator();
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdminOrOperator();
      allow create: if isOwner(uid)
        && request.resource.data.id == uid
        && request.resource.data.role == 'operador';
      allow update: if (isOwner(uid)
        && request.resource.data.id == resource.data.id
        && request.resource.data.role == resource.data.role
        && request.resource.data.institution == resource.data.institution)
        || isAdmin();
      allow delete: if isAdmin();
    }

    match /programs/{docId} {
      allow read: if true;
      allow write: if isAdminOrOperator();
    }

    match /presenters/{docId} {
      allow read: if true;
      allow write: if isAdminOrOperator();
    }

    match /media/{docId} {
      allow read: if true;
      allow write: if isAdminOrOperator();
    }

    match /playbackSequences/{sequenceId} {
      allow read: if true;
      allow write: if isAdminOrOperator();

      match /items/{itemId} {
        allow read: if true;
        allow write: if isAdminOrOperator();
      }
    }

    match /scheduleBlocks/{docId} {
      allow read: if true;
      allow write: if isAdminOrOperator();
    }

    match /auditLogs/{docId} {
      allow read, write: if isAdminOrOperator();
    }
  }
}
