rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdminOrOperator() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'operador'];
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function hasPrivilegedTokenClaim() {
      return isSignedIn() && (
        request.auth.token.role in ['ROOT', 'ADMIN', 'root', 'admin']
        || request.auth.token.admin == true
      );
    }

    function isAdminOrRoot() {
      return hasPrivilegedTokenClaim() || isAdmin();
    }

    function onlyAllowedSelfEditableUserFields() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'name',
        'nome',
        'email',
        'avatarUrl',
        'photoURL',
        'updatedAt',
        'lastLoginAt'
      ]);
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdminOrOperator();
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdminOrRoot() || isAdminOrOperator();
      allow create: if isOwner(uid)
        && request.resource.data.id == uid
        && !request.resource.data.keys().hasAny([
          'role',
          'authSource',
          'passwordHash',
          'isProtected',
          'firebaseUid',
          'status'
        ]);
      allow update: if isOwner(uid)
        && request.resource.data.id == resource.data.id
        && onlyAllowedSelfEditableUserFields()
        && !request.resource.data.diff(resource.data).changedKeys().hasAny([
          'role',
          'authSource',
          'passwordHash',
          'isProtected',
          'firebaseUid',
          'status'
        ]);
      allow delete: if false;
    }

    match /programs/{docId} {
      allow read: if true;
      allow write: if isAdminOrOperator();
    }

    match /presenters/{docId} {
      allow read: if true;
      allow write: if isAdminOrOperator();
    }

    match /media/{docId} {
      allow read: if true;
      allow write: if isAdminOrOperator();
    }

    match /playbackSequences/{sequenceId} {
      allow read: if true;
      allow write: if isAdminOrOperator();

      match /items/{itemId} {
        allow read: if true;
        allow write: if isAdminOrOperator();
      }
    }

    match /scheduleBlocks/{docId} {
      allow read: if true;
      allow write: if isAdminOrOperator();

      match /items/{itemId} {
        allow read: if true;
        allow write: if isAdminOrOperator();
      }
    }

    match /auditLogs/{docId} {
      allow read, write: if isAdminOrOperator();
    }
  }
}
