generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  EDITOR
  SCHEDULER
  OPERATOR
  VIEWER
}

enum MediaType {
  PROGRAMA
  VINHETA
  INTRODUCAO
  ENCERRAMENTO
  CHAMADA
  AUDIO
  VIDEO
  YOUTUBE_VIDEO
  LOCAL_VIDEO
  LOCAL_AUDIO
  CHAMADA_INSTITUCIONAL
}

enum SourceType {
  YOUTUBE
  LOCAL
}

enum PlaybackOverrideStatus {
  SCHEDULED
  ACTIVE
  ENDED
  CANCELED
}

enum PlaybackItemStartMode {
  FIXED_TIME
  AFTER_PREVIOUS
}

enum Weekday {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

model Institution {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  shortName         String?
  primaryColor      String?
  secondaryColor    String?
  logoUrl           String?
  bannerUrl         String?
  description       String?
  playerPosition    String   @default("bottom-right")
  playerDefaultMode String   @default("compact")
  showQueue         Boolean  @default(true)
  showCover         Boolean  @default(true)
  autoplayEnabled   Boolean  @default(false)
  fallbackMediaId   String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  users             User[]
  presenters        Presenter[]
  categories        Category[]
  programs          Program[]
  media             Media[]
  scheduleItems     ScheduleItem[]
  playbackOverrides PlaybackOverride[]
  playbackSequences PlaybackSequence[]
  scheduleBlocks    ScheduleBlock[]
  auditLogs         AuditLog[]
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  passwordHash   String
  role           UserRole @default(VIEWER)
  institutionId  String?
  institution    Institution? @relation(fields: [institutionId], references: [id])
  isActive       Boolean  @default(true)
  lastLoginAt    DateTime?
  refreshToken   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  logs           AuditLog[]
  playbackOverrides PlaybackOverride[] @relation("OverrideCreator")
}

model Presenter {
  id            String   @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])
  name          String
  slug          String
  shortBio      String?
  fullBio       String?
  photoUrl      String?
  roleTitle     String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  programs      Program[]

  @@unique([institutionId, slug])
}

model Category {
  id            String   @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])
  name          String
  slug          String
  color         String?
  description   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  programs      Program[]
  media         Media[]

  @@unique([institutionId, slug])
}

model Program {
  id               String   @id @default(cuid())
  institutionId    String
  institution      Institution @relation(fields: [institutionId], references: [id])
  presenterId      String?
  presenter        Presenter? @relation(fields: [presenterId], references: [id])
  categoryId       String?
  category         Category? @relation(fields: [categoryId], references: [id])
  title            String
  slug             String
  shortDescription String?
  fullDescription  String?
  description      String?
  coverUrl         String?
  highlightColor   String?
  tags             String[]
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  media            Media[]
  scheduleItems    ScheduleItem[]
  playbackSequences PlaybackSequence[]
  scheduleBlocks   ScheduleBlock[]

  @@unique([institutionId, slug])
}

model Media {
  id              String   @id @default(cuid())
  institutionId   String
  institution     Institution @relation(fields: [institutionId], references: [id])
  programId       String?
  program         Program? @relation(fields: [programId], references: [id])
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id])
  title           String
  mediaType       MediaType
  sourceType      SourceType
  youtubeUrl      String?
  youtubeVideoId  String?
  embedUrl        String?
  filePath        String?
  fileName        String?
  mimeType        String?
  fileSize        Int?
  publicUrl       String?
  thumbnailUrl    String?
  durationSeconds Int?
  notes           String?
  isFallback      Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  scheduleItems   ScheduleItem[]
  playbackOverrides PlaybackOverride[]
  sequenceItems   PlaybackSequenceItem[]
}

model PlaybackSequence {
  id            String   @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])
  programId     String?
  program       Program? @relation(fields: [programId], references: [id])
  title         String
  description   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items         PlaybackSequenceItem[]
  scheduleBlocks ScheduleBlock[]
  playbackOverrides PlaybackOverride[]
}

model PlaybackSequenceItem {
  id                    String   @id @default(cuid())
  sequenceId            String
  sequence              PlaybackSequence @relation(fields: [sequenceId], references: [id])
  mediaId               String
  media                 Media @relation(fields: [mediaId], references: [id])
  orderIndex            Int
  startMode             PlaybackItemStartMode
  fixedStartTime        String?
  relativeOffsetSeconds Int? @default(0)
  startAfterPrevious    Boolean @default(false)
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([sequenceId, orderIndex])
}

model ScheduleBlock {
  id            String   @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])
  programId     String?
  program       Program? @relation(fields: [programId], references: [id])
  sequenceId    String
  sequence      PlaybackSequence @relation(fields: [sequenceId], references: [id])
  title         String
  weekday       Weekday
  startTime     String
  endTime       String?
  timezone      String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([institutionId, weekday, isActive])
}

model ScheduleItem {
  id            String   @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])
  programId     String?
  program       Program? @relation(fields: [programId], references: [id])
  mediaId       String
  media         Media @relation(fields: [mediaId], references: [id])
  title         String
  weekday       Int
  startTime     String
  endTime       String
  priority      Int      @default(0)
  repeatRule    String?
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([institutionId, weekday, isActive])
}

model PlaybackOverride {
  id              String   @id @default(cuid())
  institutionId   String
  institution     Institution @relation(fields: [institutionId], references: [id])
  mediaId         String?
  media           Media? @relation(fields: [mediaId], references: [id])
  sequenceId      String?
  sequence        PlaybackSequence? @relation(fields: [sequenceId], references: [id])
  title           String
  startAt         DateTime
  endAt           DateTime?
  priority        Int      @default(0)
  status          PlaybackOverrideStatus @default(SCHEDULED)
  notes           String?
  createdByUserId String
  createdByUser   User @relation("OverrideCreator", fields: [createdByUserId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AuditLog {
  id            String   @id @default(cuid())
  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id])
  userId        String?
  user          User? @relation(fields: [userId], references: [id])
  action        String
  entity        String
  entityId      String?
  description   String?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([institutionId, createdAt])
}
